# ============================================================
# CampusEats Dashboard — Environment Variables Template
# ============================================================
# IMPORTANT: This is an EXAMPLE file showing required variables.
# DO NOT commit the actual .env file to version control!
#
# Setup Instructions:
# 1. Copy this file to .env
# 2. Fill in the values with your actual credentials
# 3. The .env file is already in .gitignore and won't be committed
# ============================================================

# --- Google Gemini API ---
# Obtain a free key at: https://aistudio.google.com/app/apikey
# Example: GEMINI_API_KEY=AQ.Ab8RN6KMZIMWy993Ty7phsS9db10ST36LZ7WhdxJJONMd0a6xA
GEMINI_API_KEY=your_gemini_api_key_here

# --- Database ---
# Relative or absolute path to the SQLite database file
# Default: sqlite:///CampusEats.db
DATABASE_URL=sqlite:///CampusEats.db

# --- Demo / Development Mode ---
# Set to "true" to allow login with ANY password when the DB
# contains placeholder hashes (pbkdf2:sha256:mockhashvalue).
# Set to "false" in production once real password hashes are loaded.
# IMPORTANT: Always set to "false" in production!
DEMO_MODE=false
